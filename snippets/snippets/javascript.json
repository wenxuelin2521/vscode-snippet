	"to_common_download_template": {
		"prefix": "toCommonDownloadTemplate",
		"body": [
			"    // 导出、下载模板代码（导入语句:  import { downloadBlobFile } from '@/csg-share/api/common';）",
			"    async exportHandler() {",
			"      const pageLoading = this.\\$loading({",
			"        lock: true,",
			"        text: '下载中....',",
			"        spinner: 'el-icon-loading',",
			"        background: 'rgba(0,0,0,0.7)',",
			"      });",
			"      const result = await DataManager.export({",
			"        pageNum: 1,",
			"        pageSize: 999999,",
			"        exportFlag: '1',",
			"      }).catch(() => {",
			"        pageLoading.close();",
			"        this.\\$message.error('下载异常，请稍后再试！');",
			"      });",
			"      // console.log('接口直接返回的result', result);",
			"      if (typeof result === 'object' && result.data && result.data.type === 'application/json') {",
			"        pageLoading.close();",
			"        const reader = new FileReader();",
			"        reader.readAsText(result.data, 'utf-8');",
			"        reader.onload = () => {",
			"          // console.log('解析后的reader.result', reader.result);",
			"          const jsonRes = JSON.parse(reader.result);",
			"          this.\\$message.error(jsonRes.msg || '下载异常，请稍后再试！');",
			"        };",
			"        return; // 直接返回了，不在往下执行！",
			"      }",
			"      downloadBlobFile(result);",
			"      pageLoading.close();",
			"    },",
		]
	},
	"to_second_confirm_template": {
		"prefix":"to_second_confirm_template",
		"body": [
			"// 二次提交确认",
			"async secondConfirm(message = '确认处理吗？') {",
			"  const isContinue = await this.\\$confirm(`\\${message}`, '提示', {",
			"    confirmButtonText: '确定',",
			"    cancelButtonText: '取消',",
			"    type: 'warning',",
			"  })",
			"    .then(() => true)",
			"    .catch(() => false);",
			"  return isContinue;",
			"},",
		]
	},
	"el_form_validate": {
		"prefix":"el_form_validate_common",
		"body": [
			"async elFormMethod() {",
			"  const isValid = await this.\\$refs.fillFormRef.validate().catch(() => false);",
			"  this.\\$refs.fillFormRef && this.\\$refs.fillFormRef.resetFields();",
			"  if (!isValid) {",
			"    return this.\\$message.warning('请完善新增信息！');",
			"  }",
			"},",
		]
	},
	"regex_num_3num": {
		"prefix":"regex_num_3num",
		"body": [
			"// 正则：正数，最多三位小数",
			"const regex = /^(0|[1-9]\\d*)(\\.\\d{1,3})?\\$/"
		],
		"description": "正则：正数，最多三位小数"
	}

	
	

}