{
	// Place your snippets for vue here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"my_vue_template": {
		"prefix": "vuetemplate",
		"body": [
			"<template>",
			"  <div class=\"$1\"></div>",
			"</template>",
			"",
			"<script>",
			"export default {",
			"  name: \"$2\",",
			"  data() {",
			"    return {};",
			"  },",
			"  methods: {},",
			"  created() {},",
			"  mounted() {}",
			"};",
			"</script>",
			"",
			"<style lang=\"scss\" scoped>",
			"@import './index.scss';",
			"</style>",


		],
		"description": "Log output to console"
	},
	"vue_gp_app_layout": {
		"prefix": "gp-app-layout",
		"body": [
			"<template>",
			"  <gp-page-layout>",
			"    <template slot=\"header-content\">",
			"      <header-bar title=\"$1\" />",
			"    </template>",
			"",
			"    <main class=\"main-container\" slot=\"body-content\">",
			"",
			"    </main>",
			"",
			"  </gp-page-layout>",
			"</template>",
			"",
			"<script>",
			"export default {",
			"  name: \"$2\",",
			"  data() {",
			"    return {};",
			"  },",
			"  methods: {",
			"  },",
			"};",
			"</script>",
			"<style lang=\"less\" scoped>",
			"@import \"./index.less\";",
			"</style>"
		]
	},
	"vue_confirm_dialog_template": {
		"prefix": "confirmDialogTemplate",
		"body": [
			"<template>",
			"  <el-dialog v-loading=\"dialogLoading\" :title=\"dialogTitle\" :visible.sync=\"visible\" width=\"800px\" :before-close=\"closeDialog\" :close-on-click-modal=\"false\">",
			"",
			"    <!-- 弹窗内容 -->",
			"",
			"    <div class=\"footer-btn-wrapper\" style=\"margin-top:20px;text-align:center;\">",
			"      <el-button type=\"primary\" @click=\"confirmHandler\">确认</el-button>",
			"      <el-button type=\"default\" @click=\"closeDialog\">返回</el-button>",
			"    </div>",
			"  </el-dialog>",
			"</template>",
			"",
			"<script>",
			"export default {",
			"  name: '$1',",
			"  props: {",
			"    visible: {",
			"      type: Boolean,",
			"      default: false,",
			"    },",
			"    rowInfo: {",
			"      type: Object,",
			"      default: () => ({}),",
			"    },",
			"  },",
			"  data() {",
			"    return {",
			"      dialogTitle: '$2',",
			"      dialogLoading: false,",
			"    };",
			"  },",
			"  computed: { },",
			"  watch: {",
			"    visible(newValue) {",
			"      if (newValue) {",
			"        this.resetHandler();",
			"        this.\\$nextTick(() => {",
			"          this.initHandler();",
			"        });",
			"      } else {",
			"        this.resetHandler();",
			"      }",
			"    },",
			"  },",
			"  created() {},",
			"  mounted() {},",
			"  methods: {",
			"    // 初始化弹窗",
			"    initHandler() {",
			"    },",
			"    // 重置弹窗信息",
			"    resetHandler() {",
			"    },",
			"    // // 关闭弹窗",
			"    closeDialog() {",
			"      this.\\$emit('update:visible', false);",
			"    },",
			"",
			"    // 保存",
			"    async confirmHandler() {",
			"      const isContinue = await this.secondConfirm(`确认保存当前数据吗？`);",
			"      if (!isContinue) {",
			"        return;",
			"      }",
			"      this.closeDialog();",
			"    },",
			"",
			"    // 二次提交确认",
			"    async secondConfirm(message = '确认处理吗？') {",
			"      // 所选数据符合要求",
			"      const isContinue = await this.\\$confirm(`\\${message}`, '提示', {",
			"        confirmButtonText: '确定',",
			"        cancelButtonText: '取消',",
			"        type: 'warning',",
			"      })",
			"        .then(() => true)",
			"        .catch(() => false);",
			"      return isContinue;",
			"    },",
			"",
			"  },",
			"};",
			"</script>",
			"",
			"<style lang=\"scss\" scoped>",
			"",
			"</style>",
			""
		]
	}
	
}